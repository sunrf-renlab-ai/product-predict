{
  "name": "product-predict",
  "version": "0.5.0",
  "description": "User experience simulation: synthetic users in a real browser, persona-driven feedback.",
  "type": "module",
  "bin": {
    "pp": "./bin/pp"
  },
  "scripts": {
    "dev": "tsx src/cli.ts",
    "build": "tsc -p .",
    "test": "node --import tsx --test src/__tests__/*.test.ts",
    "start": "node dist/cli.js",
    "postinstall": "playwright install chromium --with-deps || playwright install chromium || exit 0"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.32.1",
    "@types/pdf-parse": "^1.1.5",
    "commander": "^12.1.0",
    "mammoth": "^1.12.0",
    "pdf-parse": "^2.4.5",
    "playwright": "^1.48.0"
  },
  "devDependencies": {
    "@types/node": "^22.7.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  },
  "engines": {
    "node": ">=20"
  }
}
