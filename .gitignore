# dependencies
node_modules/
package-lock.json.bak

# build artifacts
dist/
*.tsbuildinfo

# pp-specific: per-run artifacts (screenshots, large)
pp/runs/
pp/test/target-site/__pycache__/

# Benchmark runs: keep summary + matched + scorecard + run.json + report.md,
# drop bulky regeneratable artifacts (shots, per-fixture report.html ~155KB each).
benchmark/runs/**/per-fixture/**/shots/
benchmark/runs/**/per-fixture/**/runs/run-*/shots/
benchmark/runs/**/per-fixture/**/runs/run-*/report.html

# Next.js build cache
web/.next/
web/out/

# original Anthropic Design bundle (binary input, available upstream)
design.tar.gz

# local config / secrets (defensive — pp reads from Keychain, not disk)
.env
.env.*
*.key
*.pem

# OS / editor
.DS_Store
*.swp
.vscode/
.idea/

# logs
*.log
/tmp/pp-*.log
